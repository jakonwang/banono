{
  "kind": "collectionType",
  "collectionName": "inquiries",
  "info": {
    "singularName": "inquiry",
    "pluralName": "inquiries",
    "displayName": "Inquiry"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": { "type": "string", "required": true },
    "company": { "type": "string" },
    "email": { "type": "email", "required": true },
    "phone": { "type": "string" },
    "message": { "type": "text", "required": true },
    "status": { "type": "enumeration", "enum": ["new", "processing", "quoted", "done"], "default": "new" },
    "notes": { "type": "text" }
  }
}
